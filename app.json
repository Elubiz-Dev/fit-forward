{
  "expo": {
    "name": "FitGO",
    "slug": "fitgo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F172A",
    "androidNavigationBar": {
      "barStyle": "light-content",
      "backgroundColor": "#0F172A"
    },
    "scheme": "fitgo",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fitgo.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan food barcodes and take progress photos",
        "NSMicrophoneUsageDescription": "Use voice to log food and talk with your AI coach",
        "NSPhotoLibraryUsageDescription": "Access your photo library for progress photos",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fitgo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.jpg",
        "backgroundColor": "#0D0F14"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS",
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FitGO to access your camera to scan food barcodes and take progress photos."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow FitGO to access your microphone to log food and talk with your AI coach."
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      "expo-asset",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7C5CFC"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b322d830-a5f8-4c68-83b5-8686ce3d38f3"
      }
    },
    "owner": "deathtrooper",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b322d830-a5f8-4c68-83b5-8686ce3d38f3"
    }
  }
}
