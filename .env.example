# FitGo Environment Variables
# Copia este archivo a .env y completa con tus valores reales.
# NUNCA subas .env a git — solo .env.example

# ─── Supabase ─────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Groq AI ──────────────────────────────────────────────────
EXPO_PUBLIC_GROQ_API_KEY=your-groq-api-key

# ─── Edamam Nutrition API (opcional — mejora la búsqueda) ─────
EXPO_PUBLIC_EDAMAM_APP_ID=your-edamam-app-id
EXPO_PUBLIC_EDAMAM_APP_KEY=your-edamam-app-key

# ─── RevenueCat (para suscripciones — Fase 2) ─────────────────
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=your-rc-ios-key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=your-rc-android-key
